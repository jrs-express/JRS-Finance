@page "/account/login"
@layout AuthLayout
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager Navigation

<div class="login-card">
    <div class="login-card-header">
        <h3 class="mb-1">Welcome to JRS Express</h3>
        <p class="mb-0">Sign in to continue to your accounting dashboard.</p>
    </div>

    <EditForm Model="model" OnValidSubmit="HandleLogin" FormName="login" class="login-form">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger small mb-3" />

        <div class="mb-3">
            <label class="form-label">Email</label>
            <InputText class="form-control form-control-lg" @bind-Value="model.Email" placeholder="name@jrs.local" />
        </div>

        <div class="mb-3">
            <label class="form-label">Password</label>
            <InputText class="form-control form-control-lg" type="password" @bind-Value="model.Password" placeholder="Enter password" />
        </div>

        <button class="btn btn-jrs w-100">Login</button>
    </EditForm>

    <p class="mt-3 mb-0 text-muted small">
        Seed users: admin@jrs.local / Admin@12345 and accounting@jrs.local / Accounting@12345
    </p>
</div>

@code {
    private LoginModel model = new();

    private async Task HandleLogin()
    {
        var result = await SignInManager.PasswordSignInAsync(model.Email, model.Password, true, lockoutOnFailure: false);
        if (result.Succeeded)
        {
            Navigation.NavigateTo("/");
        }
    }

    public class LoginModel
    {
        [Required, EmailAddress] public string Email { get; set; } = string.Empty;
        [Required] public string Password { get; set; } = string.Empty;
    }
}
