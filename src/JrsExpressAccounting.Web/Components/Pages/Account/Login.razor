@page "/account/login"
@layout AuthLayout
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<PageTitle>Login - JRS Express</PageTitle>

<div class="login-card">
    <div class="login-card-header">
        <h3 class="mb-1">Welcome to JRS Express</h3>
        <p class="mb-0">Sign in to continue to your accounting dashboard.</p>
    </div>

    <EditForm Model="model" OnValidSubmit="HandleLogin" FormName="login" class="login-form">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger small mb-3" />
        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger py-2" role="alert">@errorMessage</div>
        }

        <div class="mb-3">
            <label class="form-label">Email</label>
            <InputText class="form-control form-control-lg" @bind-Value="model.Email" placeholder="name@jrs.local" autocomplete="username" />
        </div>

        <div class="mb-3">
            <label class="form-label">Password</label>
            <InputText class="form-control form-control-lg" type="password" @bind-Value="model.Password" placeholder="Enter password" autocomplete="current-password" />
        </div>

        <button type="submit" class="btn btn-jrs w-100">Login</button>
    </EditForm>

    <p class="mt-3 mb-0 text-muted small">
        Seed users: admin@jrs.local / Admin@12345 and accounting@jrs.local / Accounting@12345
    </p>
</div>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private readonly LoginModel model = new();
    private string? errorMessage;

    private async Task HandleLogin()
    {
        errorMessage = null;

        var user = await UserManager.FindByEmailAsync(model.Email.Trim());
        if (user is null)
        {
            errorMessage = "Invalid email or password.";
            return;
        }

        var result = await SignInManager.PasswordSignInAsync(user, model.Password, isPersistent: true, lockoutOnFailure: false);
        if (!result.Succeeded)
        {
            errorMessage = "Invalid email or password.";
            return;
        }

        var destination = string.IsNullOrWhiteSpace(ReturnUrl) ? "/" : ReturnUrl;
        Navigation.NavigateTo(destination, forceLoad: true);
    }

    public class LoginModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        public string Password { get; set; } = string.Empty;
    }
}
