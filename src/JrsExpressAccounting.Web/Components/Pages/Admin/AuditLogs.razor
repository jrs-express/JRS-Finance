@page "/admin/audit-logs"
@attribute [Authorize(Roles = "Admin,AccountingAdmin")]
@inject JrsExpressAccounting.Web.Data.ApplicationDbContext Db

<h3>Audit Logs</h3>
<table class="table table-sm table-striped">
    <thead><tr><th>Time (UTC)</th><th>User</th><th>Action</th><th>Entity</th><th>Changes</th></tr></thead>
    <tbody>
        @foreach (var item in logs)
        {
            <tr><td>@item.Timestamp</td><td>@item.UserId</td><td>@item.Action</td><td>@item.EntityName (@item.EntityKey)</td><td>@item.Changes</td></tr>
        }
    </tbody>
</table>

@code {
    private List<AuditLog> logs = [];
    protected override async Task OnInitializedAsync() =>
        logs = await Db.AuditLogs.OrderByDescending(x => x.Timestamp).Take(200).ToListAsync();
}
