@page "/admin/users-roles"
@attribute [Authorize(Roles = "Admin")]
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager

<h3>Users and Roles</h3>
<p>Admins can add users and assign Accounting/Admin roles.</p>
<table class="table table-sm table-striped">
    <thead><tr><th>Email</th><th>Name</th><th>Roles</th></tr></thead>
    <tbody>
        @foreach (var user in users)
        {
            <tr><td>@user.Email</td><td>@user.FullName</td><td>@string.Join(", ", await UserManager.GetRolesAsync(user))</td></tr>
        }
    </tbody>
</table>

@code {
    private List<ApplicationUser> users = [];
    protected override void OnInitialized() => users = UserManager.Users.OrderBy(x => x.Email).ToList();
}
