@page "/admin/users-roles"
@attribute [Authorize(Roles = "Admin")]
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager

<h3>Users and Roles</h3>
<p>Admins can add users and assign Accounting/Admin roles.</p>
<table class="table table-sm table-striped">
    <thead><tr><th>Email</th><th>Name</th><th>Roles</th></tr></thead>
    <tbody>
        @foreach (var user in users)
        {
            <tr>
                <td>@user.Email</td>
                <td>@user.FullName</td>
                <td>@GetUserRoles(user.Id)</td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<ApplicationUser> users = [];
    private readonly Dictionary<string, string> userRoles = [];

    protected override async Task OnInitializedAsync()
    {
        users = UserManager.Users.OrderBy(x => x.Email).ToList();

        foreach (var user in users)
        {
            var roles = await UserManager.GetRolesAsync(user);
            userRoles[user.Id] = string.Join(", ", roles);
        }
    }

    private string GetUserRoles(string userId)
        => userRoles.TryGetValue(userId, out var roles) ? roles : string.Empty;
}
