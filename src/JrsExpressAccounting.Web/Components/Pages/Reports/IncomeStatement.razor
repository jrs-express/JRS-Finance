@page "/reports/income-statement"
@attribute [Authorize(Roles = "Admin,AccountingAdmin,Accounting")]
@inject IReportService Reports

<h3>Income Statement</h3>
<table class="table table-sm table-striped">
    <thead><tr><th>Type</th><th>Account</th><th>Amount</th></tr></thead>
    <tbody>
        @foreach (var item in lines)
        {
            <tr><td>@item.AccountType</td><td>@item.AccountName</td><td>@item.Amount.ToString("N2")</td></tr>
        }
    </tbody>
</table>

@code {
    private List<IncomeStatementLine> lines = [];
    protected override async Task OnInitializedAsync() =>
        lines = await Reports.GetIncomeStatementAsync(DateTime.UtcNow.AddMonths(-1), DateTime.UtcNow, null);
}
