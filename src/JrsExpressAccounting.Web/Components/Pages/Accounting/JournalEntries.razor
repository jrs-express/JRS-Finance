@page "/accounting/journal-entries"
@attribute [Authorize(Roles = "Admin,AccountingAdmin,Accounting")]
@inject JrsExpressAccounting.Web.Data.ApplicationDbContext Db

<h3>Journal Entries</h3>
<table class="table table-sm table-striped">
    <thead><tr><th>Date</th><th>Reference</th><th>Description</th><th>Branch</th></tr></thead>
    <tbody>
        @foreach (var item in entries)
        {
            <tr><td>@item.TransactionDate.ToShortDateString()</td><td>@item.ReferenceNo</td><td>@item.Description</td><td>@item.Branch?.Name</td></tr>
        }
    </tbody>
</table>

@code {
    private List<JournalEntry> entries = [];

    protected override async Task OnInitializedAsync() =>
        entries = await Db.JournalEntries.Include(x => x.Branch).OrderByDescending(x => x.TransactionDate).ToListAsync();
}
